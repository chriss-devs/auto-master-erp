{
  "name": "auto-master-api",
  "private": true,
  "version": "0.1.0",
  "description": "API NestJS del ERP Auto Master Colón (monolito modular)",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "vercel-build": "prisma generate && tsc -p tsconfig.build.json",
    "dev": "ts-node --transpile-only src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "jest --config jest.config.js",
    "test:int": "jest --config jest.integration.config.js --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:diff": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@prisma/client": "^6.12.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.30.0",
    "jest": "^29.7.0",
    "prisma": "^6.12.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0"
  },
  "engines": {
    "node": ">=20"
  }
}
