# Conexión a Supabase (pooler para runtime, directa para migraciones)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Servidor
PORT=4000
NODE_ENV=development

# CORS/cookies (origen del web que proxya /api)
WEB_ORIGIN=http://localhost:3000
COOKIE_SECURE=false

# Asistente (DeepSeek — spec docs/superpowers/specs/2026-07-11-asistente-chatbot-design.md)
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
# DEEPSEEK_BASE_URL solo para tests (default https://api.deepseek.com)
